---
/**
 * Top sticky bar — shared across every page.
 * Highlights the current country in --gold.
 *
 * Usage:
 *   <Eubar current="pt" />     // marks Portugal as active
 *   <Eubar current="home" />   // home page
 */
type CountryKey = 'home' | 'pt' | 'es' | 'fr' | 'de' | 'it' | 'nl' | 'ie' | 'be' | 'at' | 'se';
interface Props { current: CountryKey }
const { current } = Astro.props as Props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (slug: string) => `${base}/${slug}`;
const cls  = (k: CountryKey) => current === k ? 'current' : '';
---
<div class="eubar">
  <div class="eubar-inner">
    <a href={link('')} class="eubar-home">🇪🇺 <strong>EU Stats</strong></a>
    <nav class="eubar-nav">
      <a href={link('')} class={cls('home')}>Home</a>
      <a href={link('portugal')}    class={cls('pt')} title="Portugal">🇵🇹</a>
      <a href={link('spain')}       class={cls('es')} title="Spain">🇪🇸</a>
      <a href={link('france')}      class={cls('fr')} title="France">🇫🇷</a>
      <a href={link('germany')}     class={cls('de')} title="Germany">🇩🇪</a>
      <a href={link('italy')}       class={cls('it')} title="Italy">🇮🇹</a>
      <a href={link('netherlands')} class={cls('nl')} title="Netherlands">🇳🇱</a>
      <a href={link('ireland')}     class={cls('ie')} title="Ireland">🇮🇪</a>
      <a href={link('belgium')}     class={cls('be')} title="Belgium">🇧🇪</a>
      <a href={link('austria')}     class={cls('at')} title="Austria">🇦🇹</a>
      <a href={link('sweden')}      class={cls('se')} title="Sweden">🇸🇪</a>
    </nav>
  </div>
</div>
