---
/**
 * Top sticky bar — shared across every page.
 * Shows: brand · Home link · country switcher (dropdown).
 *
 * The dropdown groups countries by region and scales to 27 EU member
 * states (and beyond). Uses native <details>/<summary> for zero-JS
 * basic behaviour, with a small enhancement to close on outside click.
 *
 * Usage:
 *   <Eubar current="pt" />     // marks Portugal as active
 *   <Eubar current="home" />   // home page
 */
type CountryKey = 'home' | 'pt' | 'es' | 'fr' | 'de' | 'it' | 'nl' | 'ie' | 'be' | 'at' | 'se' | 'pl' | 'cz' | 'gr' | 'dk' | 'fi';
interface Props { current: CountryKey }
const { current } = Astro.props as Props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (slug: string) => `${base}/${slug}`;

// Country catalogue — single place to add new countries
interface CountryEntry { key: CountryKey; name: string; slug: string; flag: string }
const SOUTHERN: CountryEntry[] = [
  { key: 'pt', name: 'Portugal', slug: 'portugal', flag: '🇵🇹' },
  { key: 'es', name: 'Spain',    slug: 'spain',    flag: '🇪🇸' },
  { key: 'it', name: 'Italy',    slug: 'italy',    flag: '🇮🇹' },
  { key: 'gr', name: 'Greece',   slug: 'greece',   flag: '🇬🇷' },
];
const WESTERN: CountryEntry[] = [
  { key: 'fr', name: 'France',      slug: 'france',      flag: '🇫🇷' },
  { key: 'de', name: 'Germany',     slug: 'germany',     flag: '🇩🇪' },
  { key: 'nl', name: 'Netherlands', slug: 'netherlands', flag: '🇳🇱' },
  { key: 'be', name: 'Belgium',     slug: 'belgium',     flag: '🇧🇪' },
  { key: 'at', name: 'Austria',     slug: 'austria',     flag: '🇦🇹' },
  { key: 'ie', name: 'Ireland',     slug: 'ireland',     flag: '🇮🇪' },
];
const CENTRAL_EASTERN: CountryEntry[] = [
  { key: 'pl', name: 'Poland',   slug: 'poland',  flag: '🇵🇱' },
  { key: 'cz', name: 'Czechia',  slug: 'czechia', flag: '🇨🇿' },
];
const NORDIC: CountryEntry[] = [
  { key: 'se', name: 'Sweden',   slug: 'sweden',  flag: '🇸🇪' },
  { key: 'dk', name: 'Denmark',  slug: 'denmark', flag: '🇩🇰' },
  { key: 'fi', name: 'Finland',  slug: 'finland', flag: '🇫🇮' },
];

const REGIONS = [
  { label: 'Southern Europe',     items: SOUTHERN        },
  { label: 'Western Europe',      items: WESTERN         },
  { label: 'Central & Eastern',   items: CENTRAL_EASTERN },
  { label: 'Northern Europe',     items: NORDIC          },
];

// Find the currently-selected country (or null on home)
const allCountries = [...SOUTHERN, ...WESTERN, ...CENTRAL_EASTERN, ...NORDIC];
const activeCountry = allCountries.find((c) => c.key === current) ?? null;
---
<div class="eubar">
  <div class="eubar-inner">
    <a href={link('')} class="eubar-home">🇪🇺 <strong>EU Stats</strong></a>

    <div class="eubar-right">
      <a href={link('')} class={`eubar-link${current === 'home' ? ' current' : ''}`}>Home</a>

      <details class="cswitch">
        <summary class="cswitch-trigger" aria-label="Select country">
          {activeCountry ? (
            <>
              <span class="cs-flag">{activeCountry.flag}</span>
              <span class="cs-name">{activeCountry.name}</span>
            </>
          ) : (
            <>
              <span class="cs-flag">🗺</span>
              <span class="cs-name">Browse {allCountries.length} countries</span>
            </>
          )}
          <span class="cs-caret" aria-hidden="true">▾</span>
        </summary>

        <div class="cswitch-menu" role="menu">
          <input
            type="search"
            class="cs-search"
            placeholder="Search country…"
            aria-label="Search country"
          />
          {REGIONS.map((reg) => (
            <div class="cs-group">
              <div class="cs-group-label">{reg.label}</div>
              {reg.items.map((c) => (
                <a
                  href={link(c.slug)}
                  class={`cs-item${c.key === current ? ' current' : ''}`}
                  data-name={c.name.toLowerCase()}
                  role="menuitem"
                >
                  <span class="cs-flag">{c.flag}</span>
                  <span class="cs-name">{c.name}</span>
                  {c.key === current && <span class="cs-check" aria-hidden="true">✓</span>}
                </a>
              ))}
            </div>
          ))}
        </div>
      </details>
    </div>
  </div>
</div>

<!-- Outside-click close + keyboard / search filter — tiny inline script -->
<script is:inline>
  (function () {
    const root = document.querySelector('details.cswitch');
    if (!root) return;
    const search = root.querySelector('.cs-search');
    const items  = root.querySelectorAll('.cs-item');
    const groups = root.querySelectorAll('.cs-group');

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) root.removeAttribute('open');
    });

    // Close with Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.open) {
        root.removeAttribute('open');
        root.querySelector('summary')?.focus();
      }
    });

    // Auto-focus the search field when the menu opens
    root.addEventListener('toggle', () => {
      if (root.open && search) {
        search.value = '';
        // Reveal all items again
        items.forEach((it) => (it.style.display = ''));
        groups.forEach((g) => (g.style.display = ''));
        setTimeout(() => search.focus(), 30);
      }
    });

    // Simple filter — substring match against country name
    if (search) {
      search.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        items.forEach((it) => {
          const match = !q || (it.dataset.name || '').includes(q);
          it.style.display = match ? '' : 'none';
        });
        // Hide groups whose all items are filtered out
        groups.forEach((g) => {
          const visible = g.querySelectorAll('.cs-item:not([style*="none"])').length;
          g.style.display = visible ? '' : 'none';
        });
      });

      // Enter on search → navigate to first visible result
      search.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const first = root.querySelector('.cs-item:not([style*="none"])');
          if (first) window.location.href = first.href;
        }
      });
    }
  })();
</script>
