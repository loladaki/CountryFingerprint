---
/**
 * <InteractiveMap> — D3 choropleth map with metric switcher.
 *
 *   <InteractiveMap
 *     regions={countryData.regions}
 *     metrics={countryData.mapMetrics}
 *     geojsonUrl="https://cdn.jsdelivr.net/gh/openpolis/geojson-italy@master/geojson/limits_IT_regions.geojson"
 *     projection={{ center: [12.5, 42.5], scale: 2200, translate: [275, 310] }}
 *     featureIdResolver="(f) => String(f.properties?.reg_istat_code ?? '').padStart(2, '0')"
 *     viewBox="0 0 550 620"
 *     strokeOnSelect="#008C45"
 *     unit="regione"
 *   />
 *
 * The component injects:
 *   - SVG canvas
 *   - Metric button grid
 *   - Legend (gradient + min/max)
 *   - Side panel (per-region details on click)
 *
 * All interactive logic ships as inline <script> via define:vars so the
 * REGIONS data and metric config travel with the page (no extra fetch).
 */
import type { RegionMap, MetricConfig, ProjectionConfig } from '@data/types';

interface Props {
  regions: RegionMap;
  metrics: Record<string, MetricConfig>;
  metricButtons: { key: string; label: string }[];
  geojsonUrl: string;
  projection: ProjectionConfig;
  /** A JS expression (as string) that maps a GeoJSON feature → REGIONS id */
  featureIdResolver: string;
  /** SVG viewBox, defaults to "0 0 550 620" */
  viewBox?: string;
  /** Stroke colour when a region is selected */
  strokeOnSelect?: string;
  /** Singular noun for the prompt ("Click a {unit} on the map") */
  unit?: string;
  /** Country tag prefixed to data labels */
  country: 'pt' | 'es' | 'fr' | 'de' | 'it' | 'nl' | 'ie' | 'be' | 'at' | 'se' | 'pl' | 'cz' | 'gr' | 'dk' | 'fi' | 'ee' | 'lv' | 'lt' | 'hu' | 'sk' | 'si' | 'hr' | 'ro' | 'bg' | 'lu' | 'mt' | 'cy';
}

const {
  regions,
  metrics,
  metricButtons,
  geojsonUrl,
  projection,
  featureIdResolver,
  viewBox = '0 0 550 620',
  strokeOnSelect = '#1a3d2b',
  unit = 'region',
  country,
} = Astro.props as Props;
---
<style>
  .map-wrap{display:grid;grid-template-columns:1fr 360px;gap:1.5rem;align-items:start}
  @media(max-width:900px){.map-wrap{grid-template-columns:1fr}}
  .map-ctrl{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem}
  .metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:1.25rem}
  .metric-btn{padding:.5rem .6rem;background:var(--cream);border:1px solid var(--border);border-radius:8px;font-size:.75rem;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s;font-family:var(--font-u);text-align:center;line-height:1.3}
  .metric-btn:hover{background:var(--accent-light);border-color:var(--accent-mid);color:var(--accent)}
  .metric-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
  .map-legend{margin:.75rem 0}
  .legend-bar{width:100%;height:12px;border-radius:6px;margin:.4rem 0}
  .legend-ends{display:flex;justify-content:space-between;font-family:var(--font-m);font-size:.7rem;color:var(--muted)}
  .dp-name{font-family:var(--font-d);font-size:1.1rem;font-weight:600;color:var(--accent);margin-bottom:.75rem}
  .dp-row{display:flex;justify-content:space-between;align-items:center;padding:.38rem 0;border-top:1px solid var(--border);font-size:.81rem}
  .dp-row:first-of-type{border-top:none}
  .dp-key{color:var(--muted)}
  .dp-v{font-family:var(--font-m);font-weight:500;color:var(--text)}
  #map-svg{width:100%;height:auto;cursor:pointer;display:block}
  #map-svg .region{transition:opacity .15s,stroke-width .15s,filter .15s;filter:drop-shadow(0 1px 1px rgba(0,0,0,.06))}
  #map-svg .region:hover{opacity:.88;stroke-width:1.6;filter:drop-shadow(0 2px 3px rgba(0,0,0,.14))}
  #map-svg .region-noData{fill:#eceae6;stroke:#d6d2cb;stroke-width:.5;filter:none}
  .map-tip{position:fixed;background:var(--accent);color:#fff;padding:.5rem .9rem;border-radius:8px;font-size:.8rem;pointer-events:none;z-index:999;display:none;max-width:200px;box-shadow:0 4px 12px rgba(0,0,0,.18)}
  .map-tip .tip-val{font-family:var(--font-m);color:var(--gold);font-size:.9rem;display:block;margin-top:.1rem}
</style>

<div class="map-tip" id="map-tip"></div>
<div class="map-wrap fade">
  <div>
    <div class="chart-card" style="padding:1rem">
      <svg id="map-svg" viewBox={viewBox} xmlns="http://www.w3.org/2000/svg"></svg>
    </div>
  </div>
  <div>
    <div class="map-ctrl">
      <div style="font-size:.75rem;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.75rem">
        Displayed metric
      </div>
      <div class="metric-grid">
        {metricButtons.map((m, i) => (
          <button class={`metric-btn${i === 0 ? ' active' : ''}`} data-metric={m.key}>{m.label}</button>
        ))}
      </div>
      <div class="map-legend">
        <div style="font-size:.72rem;color:var(--muted);margin-bottom:.35rem" id="legend-title">—</div>
        <div class="legend-bar" id="legend-bar"></div>
        <div class="legend-ends"><span id="legend-min">—</span><span id="legend-max">—</span></div>
      </div>
      <div id="district-panel" style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border)">
        <div style="font-size:.78rem;color:var(--dim);text-align:center;padding:.5rem 0">← Click a {unit} on the map</div>
      </div>
    </div>
  </div>
</div>

<!-- D3 + topojson-client loaded from CDN — only on pages with the map -->
<script src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js" is:inline></script>

<script
  is:inline
  define:vars={{
    REGIONS: regions,
    METRICS: metrics,
    geojsonUrl,
    projection,
    featureIdResolver,
    strokeOnSelect,
    country,
  }}
>
  (function initMap() {
    if (typeof d3 === 'undefined') {
      const el = document.querySelector('#map-svg');
      if (el) el.innerHTML =
        '<text x="275" y="310" text-anchor="middle" fill="#9e9b96" font-family="DM Sans" font-size="13">Map requires an internet connection</text>';
      return;
    }

    // Hydrate the feature-id resolver from string form
    const resolveId = new Function('f', 'return (' + featureIdResolver + ')(f);');

    let activeMetric = Object.keys(METRICS)[0];

    const svgEl = d3.select('#map-svg');
    const tip   = document.getElementById('map-tip');
    // Parse the viewBox (e.g. "0 0 550 620") so fitExtent always picks
    // padding relative to the actual canvas — no more manually tuning
    // scale/center per country.
    const viewBoxAttr = svgEl.attr('viewBox') || '0 0 550 620';
    const [, , vbW, vbH] = viewBoxAttr.split(/\s+/).map(Number);
    const PAD = 18;            // canvas-edge breathing room

    const proj  = d3.geoMercator();
    const pathFn = d3.geoPath().projection(proj);

    // Manual projection settings stay available as a fallback (or for
    // countries that opt in via `autoFit: false`) but the default is
    // auto-fit.
    const useAutoFit = projection.autoFit !== false;
    if (!useAutoFit && projection.center) {
      proj
        .center(projection.center)
        .scale(projection.scale || 4000)
        .translate(projection.translate || [vbW / 2, vbH / 2]);
    }

    function getColor(id) {
      const data = REGIONS[id];
      if (!data) return '#e8e8e8';
      const m    = METRICS[activeMetric];
      const vals = Object.values(REGIONS).map((d) => d[activeMetric]);
      const mn   = Math.min(...vals), mx = Math.max(...vals);
      const t    = mx === mn ? 0.5 : (data[activeMetric] - mn) / (mx - mn);
      return d3.interpolateRgb(m.colors[0], m.colors[1])(t);
    }

    const fmt = {
      currency:    (v) => v.toLocaleString('en-GB') + '€',
      currencyPerM2: (v) => v.toLocaleString('en-GB') + '€/m²',
      currencyPerMo: (v) => v.toLocaleString('en-GB') + '€/mo',
      population:  (v) => v.toLocaleString('en-GB') + ' pop.',
      percent:     (v) => v.toFixed(1) + '%',
      permille:    (v) => v.toFixed(1) + '‰',
      degrees:     (v) => v.toFixed(1) + '°C',
      doctors:     (v) => v.toFixed(1) + '/1,000',
    };
    const fmtFor = (m) => fmt[m.format] || ((v) => String(v));

    function updateLegend() {
      const m    = METRICS[activeMetric];
      const vals = Object.values(REGIONS).map((d) => d[activeMetric]);
      const fn   = fmtFor(m);
      const set = (id, t) => { const e = document.getElementById(id); if (e) e.textContent = t; };
      set('legend-title', m.label);
      set('legend-min',   fn(Math.min(...vals)));
      set('legend-max',   fn(Math.max(...vals)));
      const bar = document.getElementById('legend-bar');
      if (bar) bar.style.background = `linear-gradient(to right,${m.colors[0]},${m.colors[1]})`;
    }

    function renderRegion(id) {
      const data = REGIONS[id]; if (!data) return;
      svgEl.selectAll('path.region')
        .attr('stroke-width', (p) => p.id === id ? 2.4 : 0.9)
        .attr('stroke',       (p) => p.id === id ? strokeOnSelect : '#ffffff');
      const panel = document.getElementById('district-panel');
      if (!panel) return;
      const rows = Object.keys(METRICS).map((key) => {
        const m  = METRICS[key];
        const fn = fmtFor(m);
        return `<div class="dp-row"><span class="dp-key">${m.dpKey || m.label}</span><span class="dp-v">${fn(data[key])}</span></div>`;
      }).join('');
      panel.innerHTML = `<div class="dp-name">${data.name}</div>` + rows;
    }

    // Load GeoJSON or TopoJSON and draw
    d3.json(geojsonUrl).then((raw) => {
      // Detect TopoJSON by presence of `.objects` and the topojson global
      let geo;
      if (raw && raw.objects && typeof topojson !== 'undefined') {
        const objKey = Object.keys(raw.objects)[0];
        geo = topojson.feature(raw, raw.objects[objKey]);
      } else {
        geo = raw;
      }
      const features = (geo.features || [])
        .map((f) => ({ ...f, id: resolveId(f) }))
        .filter((f) => REGIONS[f.id]);

      // Auto-fit: make the country fill the canvas with PAD padding,
      // regardless of size (LU, MT, CY, etc. were getting lost before)
      if (useAutoFit && features.length) {
        const fc = { type: 'FeatureCollection', features };
        proj.fitExtent([[PAD, PAD], [vbW - PAD, vbH - PAD]], fc);
      }

      svgEl.selectAll('path').data(features).join('path')
        .attr('class', 'region')
        .attr('d', pathFn)
        .attr('stroke', '#ffffff')
        .attr('stroke-width', 0.9)
        .attr('stroke-linejoin', 'round')
        .attr('fill', (d) => getColor(d.id))
        .style('cursor', 'pointer')
        .on('mousemove', (event, d) => {
          const data = REGIONS[d.id]; if (!data) return;
          const m  = METRICS[activeMetric];
          const fn = fmtFor(m);
          if (tip) {
            tip.style.display = 'block';
            tip.style.left = (event.clientX + 14) + 'px';
            tip.style.top  = (event.clientY - 10) + 'px';
            tip.innerHTML  =
              '<strong>' + data.name + '</strong><span class="tip-val">' +
              fn(data[activeMetric]) + '</span>';
          }
        })
        .on('mouseleave', () => { if (tip) tip.style.display = 'none'; })
        .on('click', (e, d) => renderRegion(d.id));

      updateLegend();
    }).catch((err) => {
      console.warn('Map load failed:', err.message);
      const el = document.querySelector('#map-svg');
      if (el) el.innerHTML =
        '<text x="275" y="310" text-anchor="middle" fill="#9e9b96" font-family="DM Sans" font-size="13">Map data could not be loaded</text>';
    });

    document.querySelectorAll('.metric-btn').forEach((btn) => {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.metric-btn').forEach((b) => b.classList.remove('active'));
        this.classList.add('active');
        activeMetric = this.dataset.metric;
        svgEl.selectAll('path').transition().duration(500).attr('fill', (d) => getColor(d.id));
        updateLegend();
      });
    });
  })();
</script>
