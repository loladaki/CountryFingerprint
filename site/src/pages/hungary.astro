---
import CountryLayout from '@layouts/CountryLayout.astro';
import Section from '@components/Section.astro';
import Notice from '@components/Notice.astro';
import Cards from '@components/Cards.astro';
import MetricCard from '@components/MetricCard.astro';
import KPIRow from '@components/KPIRow.astro';
import InteractiveMap from '@components/InteractiveMap.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import LiveDataLoader from '@components/LiveDataLoader.astro';
import TimeChart from '@components/TimeChart.astro';
import data from '@data/hu.json';

const h = data.history;
const flagColor = '#477050';
---
<CountryLayout country="hu" title={data.meta.title} flag={data.meta.flag} subtitle={data.meta.subtitle} description={data.meta.description} tickerItems={data.tickerItems} sections={data.sections} liveBadge="📌 Static data · loading…">
  <Section id="combustiveis" title="Energy &amp; Fuel" tag="EU Oil Bulletin · weekly">
    <Notice variant="info" icon="⛽">
      Hungarian fuel is <strong>among the cheapest in the EU</strong> — the government still
      shields prices via tax cuts. Hungary remains heavily dependent on Russian gas pipelines
      (~85% supply) and the Paks nuclear plant.
    </Notice>
    <Cards>
      <MetricCard label="⛽ Benzin 95" value={data.fuelFallback.gasolina95.atual} unit="€/L" valueId="val-g95" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="EU Oil Bulletin · May 2026" variant="gold" />
      <MetricCard label="⛽ Dízel" value={data.fuelFallback.gasoleo.atual} unit="€/L" valueId="val-gsl" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="EU Oil Bulletin · May 2026" variant="red" />
      <MetricCard label="🛢 Brent Crude" value="—" unit="$/bbl" valueId="val-brent" badge={{ kind: 'ne', text: '→ Live data' }} source="Yahoo Finance · live" />
      <MetricCard label="⚡ Electricity" value="0.13" unit="€/kWh" sub="Regulated tariff (rezsicsökkentés)" badge={{ kind: 'dn', text: '↓ Cheapest in EU' }} source="MEKH · Q1 2026" variant="green" />
      <MetricCard label="☢️ Nuclear share" value="50" unit="%" sub="Paks I + Paks II (under construction)" source="MVM · 2025" />
    </Cards>
  </Section>

  <Section id="mapa" title="Interactive Map by Region" tag="9 metrics · click a region">
    <InteractiveMap regions={data.map.regions} metrics={data.map.metrics} metricButtons={data.map.buttons} geojsonUrl={data.map.geojsonUrl} projection={data.map.projection} featureIdResolver={data.map.featureIdResolver} viewBox={data.map.viewBox} strokeOnSelect={data.map.strokeOnSelect} unit={data.map.regionUnit} country="hu" />
  </Section>

  <Section id="habitacao" title="Housing — Buy &amp; Rent" tag="KSH · Q4 2025">
    <Notice variant="warn" icon="🏠">
      Budapest housing prices <strong>tripled since 2014</strong> — among the EU's fastest growth.
      Generous CSOK family subsidies and Airbnb concentration both fuelled the boom. Rural
      Northern Hungary remains very cheap.
    </Notice>
    <Cards>
      <MetricCard label="🛒 Buy · Budapest" value="2,800" unit="€/m²" badge={{ kind: 'up', text: '↑ 3× since 2014' }} source="ingatlan.com · 2025" variant="red" />
      <MetricCard label="🛒 Buy · national avg" value="1,400" unit="€/m²" badge={{ kind: 'up', text: '↑ +6% vs 2024' }} source="KSH · 2025" />
      <MetricCard label="🛒 Buy · NE Hungary" value="950" unit="€/m²" badge={{ kind: 'dn', text: '↓ Among EU\'s cheapest' }} source="ingatlan.com · 2025" />
      <MetricCard label="🔑 Rent · Budapest (T2)" value="750" unit="€/mo" badge={{ kind: 'up', text: '↑ Highest in HU' }} source="ingatlan.com · Q1 2026" variant="blue" />
      <MetricCard label="🔑 Rent · regional (T2)" value="420" unit="€/mo" source="ingatlan.com · Q1 2026" />
    </Cards>
  </Section>

  <Section id="rendimentos" title="Income &amp; Work" tag="KSH / Eurostat · 2025–2026">
    <Cards>
      <MetricCard label="💶 Average gross salary" value={data.stats.avgGrossSalary.value} unit="€/mo" sub="HUF 615k/mo" source="KSH · 2025" variant="gold" />
      <MetricCard label="💶 Average net salary" value={data.stats.avgNetSalary.value} unit="€/mo" source="KSH · 2025" />
      <MetricCard label="📋 Minimum wage 2026" value={data.stats.minWage.value} unit="€/mo" sub="HUF 290,800/mo" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="Government · 2026" />
      <MetricCard label="📉 Unemployment" value={data.stats.unemployment.value} unit="%" valueId="hu-unemp" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source={data.stats.unemployment.source} variant="green" />
      <MetricCard label="👶 Youth unemployment" value={data.stats.youthUnemp.value} unit="%" valueId="hu-youth-unemp" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="Eurostat · Q1 2026" variant="green" />
    </Cards>
  </Section>

  <Section id="economia" title="Economy" tag="KSH / MNB · 2025–2026">
    <Notice variant="info" icon="📊">
      Hungary is a <strong>CEE auto powerhouse</strong> — Audi, Mercedes, BMW and Suzuki all build
      cars here, with BYD and CATL opening EV/battery mega-plants. The other side: EU funds are
      partially frozen over rule-of-law concerns, and inflation hit <strong>17% in 2023</strong>.
    </Notice>
    <KPIRow items={[
      { value: data.stats.gdpTotalEuro.value, label: 'GDP 2025 (€)', badge: { text: 'Mid-sized EU', kind: 'info' } },
      { value: data.stats.gdpPerCapita.value, label: 'GDP per capita', badge: { text: 'Below avg', kind: 'bad' } },
      { value: '+' + data.stats.gdp.value + '%', label: 'GDP growth 2026', valueId: 'hu-gdp', badge: { text: '↑ Above avg', kind: 'good' } },
      { value: data.stats.inflation.value + '%', label: 'Inflation 2026', valueId: 'hu-inflation', badge: { text: '↑ Above avg', kind: 'bad' } },
      { value: data.stats.publicDebt.value + '%', label: 'Public debt / GDP', badge: { text: '↓ Below avg', kind: 'ok' } },
      { value: data.stats.budgetBalance.value + '%', label: 'Budget deficit', badge: { text: '↑ Above limit', kind: 'bad' } },
    ]} />
  </Section>

  <Section id="evolucao" title="Trends Over Time" tag="2016–2025 · Eurostat">
    <Notice variant="info" icon="📈">
      The inflation chart shows Hungary's <strong>17% spike of 2023</strong> — the highest in the
      EU that year. Unemployment has been structurally low (~4%) since 2018. Public debt held
      between 65% and 80% throughout.
    </Notice>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem">
      <TimeChart id="hu-evo-gdp" title="GDP growth (%)" years={h.years} unit="%" series={[{key:'hu',label:'Hungary',color:flagColor,data:h.gdp},{key:'eu',label:'EU avg',color:'#888',data:h.euAvg.gdp,dashed:true}]} />
      <TimeChart id="hu-evo-unemp" title="Unemployment rate (%)" years={h.years} unit="%" series={[{key:'hu',label:'Hungary',color:flagColor,data:h.unemployment},{key:'eu',label:'EU avg',color:'#888',data:h.euAvg.unemployment,dashed:true}]} />
      <TimeChart id="hu-evo-infl" title="Inflation (HICP %)" years={h.years} unit="%" series={[{key:'hu',label:'Hungary',color:flagColor,data:h.inflation},{key:'eu',label:'EU avg',color:'#888',data:h.euAvg.inflation,dashed:true}]} />
      <TimeChart id="hu-evo-debt" title="Public debt (% GDP)" years={h.years} unit="%" series={[{key:'hu',label:'Hungary',color:flagColor,data:h.publicDebt},{key:'eu',label:'EU avg',color:'#888',data:h.euAvg.publicDebt,dashed:true}]} />
    </div>
  </Section>

  <Section id="turismo" title="Tourism" tag="VisitHungary · 2024">
    <Cards>
      <MetricCard label="🌍 Arrivals 2024" value="16" unit="M" badge={{ kind: 'dn', text: '↑ Record high' }} source="KSH · 2024" variant="green" />
      <MetricCard label="💶 Tourism revenue" value="8" unit="B €" badge={{ kind: 'dn', text: '↑ ~4% of GDP' }} source="VisitHungary · 2024" variant="gold" />
      <MetricCard label="♨️ Budapest spas" value="118" sub="Geothermal baths city-wide" badge={{ kind: 'ok', text: '✓ Unique in EU' }} source="Budapest.com · 2024" />
      <MetricCard label="🍷 Lake Balaton" value="6" unit="M" sub="Domestic + Austrian + German" source="KSH · 2024" />
    </Cards>
  </Section>

  <Section id="saude" title="Healthcare" tag="Eurostat · 2024">
    <Cards>
      <MetricCard label="🎂 Life expectancy" value={data.stats.lifeExpectancy.value} unit="yrs" badge={{ kind: 'up', text: '↑ Below EU avg' }} source="Eurostat · 2024" variant="red" />
      <MetricCard label="💰 Health expenditure" value="7.0" unit="% GDP" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="OECD · 2023" />
      <MetricCard label="👨‍⚕️ Doctors / 1000" value="3.5" badge={{ kind: 'ne', text: '→ Near EU avg' }} source="Eurostat · 2023" />
      <MetricCard label="🩺 Coverage" value="100" unit="%" sub="OEP single-payer" badge={{ kind: 'ok', text: '✓ Universal' }} source="OEP · 2024" />
    </Cards>
  </Section>

  <Section id="seguranca" title="Safety" tag="IEP · 2024">
    <Cards>
      <MetricCard label="🌍 Global Peace Rank" value="17" sub="17th safest globally" badge={{ kind: 'dn', text: '↑ Top-20' }} source="IEP · 2024" variant="green" />
      <MetricCard label="🚔 Homicide rate" value="0.9" unit="/100k" badge={{ kind: 'dn', text: '↓ Below EU avg' }} source="Eurostat · 2023" variant="green" />
      <MetricCard label="🚗 Road fatalities" value="600" sub="2024" badge={{ kind: 'ne', text: '→ Falling' }} source="KSH · 2024" />
    </Cards>
  </Section>

  <Section id="social" title="Society" tag="KSH / Eurostat · 2024–2025">
    <Cards>
      <MetricCard label="👥 Population" value={data.stats.population.value} sub="Slowly shrinking" source="KSH · 2026" />
      <MetricCard label="🎓 University graduates" value="33" unit="%" sub="25–34 cohort" badge={{ kind: 'up', text: '↑ Below EU avg' }} source="Eurostat · 2024" />
      <MetricCard label="👶 Birth rate" value="1.55" badge={{ kind: 'dn', text: '↑ Above EU avg' }} source="KSH · 2024" variant="green" />
      <MetricCard label="🏠 Home ownership" value="92" unit="%" sub="Among EU's highest" badge={{ kind: 'ok', text: '✓ Very high' }} source="Eurostat · 2024" />
    </Cards>
  </Section>

  <Section id="europa" title="Hungary vs Europe" tag="Eurostat · 2025–2026">
    <ComparisonTable countryLabel="Hungary" rows={[
      { indicator: 'GDP per capita',     country: '€19,500', eu: '€34,900', rank: 'bad',  note: 'Below avg (-44%)' },
      { indicator: 'GDP growth 2026',    country: '+2.0%',   eu: '+1.5%',   rank: 'good', note: 'Above avg' },
      { indicator: 'Unemployment',       country: '4.5%',    eu: '6.0%',    rank: 'good', note: 'Below avg' },
      { indicator: 'Youth unemployment', country: '13.0%',   eu: '15.4%',   rank: 'good', note: 'Below avg' },
      { indicator: 'Inflation 2026',     country: '4.5%',    eu: '2.6%',    rank: 'bad',  note: 'Above avg' },
      { indicator: 'Public debt',        country: '74% GDP', eu: '83% GDP', rank: 'ok',   note: 'Slightly below' },
      { indicator: 'Min. wage',          country: '€720',    eu: '~€1,100', rank: 'bad',  note: 'Below avg' },
      { indicator: 'Petrol price',       country: '€1.69/L', eu: '€1.82/L', rank: 'good', note: 'Below avg' },
      { indicator: 'Life expectancy',    country: '76.2 yrs', eu: '81.2 yrs', rank: 'bad', note: 'Below avg' },
    ]} />
  </Section>

  <LiveDataLoader country="hu" />

  <Fragment slot="footer-sources">
    {data.footerSources.map((s) => (<li><a href={s.url}>{s.name}</a> — {s.desc}</li>))}
  </Fragment>
  <Fragment slot="footer-badge">
    🇭🇺 Hungary · Live API<br />
    <span style="opacity:.5;font-size:.7rem;margin-top:.4rem;display:block">KSH · MNB · Eurostat</span>
  </Fragment>
</CountryLayout>
