---
import BaseLayout from '@layouts/BaseLayout.astro';

// Pull country meta from each JSON so the home page is always in sync
import pt from '@data/pt.json';
import es from '@data/es.json';
import fr from '@data/fr.json';
import de from '@data/de.json';
import it from '@data/it.json';
import nl from '@data/nl.json';
import ie from '@data/ie.json';
import be from '@data/be.json';
import at from '@data/at.json';
import se from '@data/se.json';
import pl from '@data/pl.json';
import cz from '@data/cz.json';
import gr from '@data/gr.json';
import dk from '@data/dk.json';
import fi from '@data/fi.json';
import ee from '@data/ee.json';
import lv from '@data/lv.json';
import lt from '@data/lt.json';
import hu from '@data/hu.json';
import sk from '@data/sk.json';
import si from '@data/si.json';
import hr from '@data/hr.json';
import ro from '@data/ro.json';
import bg from '@data/bg.json';
import lu from '@data/lu.json';
import mt from '@data/mt.json';
import cy from '@data/cy.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [
  { ...pt, slug: 'portugal',    blurb: 'Lowest cost of living in W. Europe · safest big country in EU · rising tourism',           highlights: { unemp: 5.8, gdp: '+2.4%', tax: 'IRS Jovem' } },
  { ...es, slug: 'spain',       blurb: 'Fastest-growing big-EU economy · 94M tourists · 30 paid leave days · housing crisis',      highlights: { unemp: 10.3, gdp: '+2.9%', tax: 'Beckham law' } },
  { ...fr, slug: 'france',      blurb: 'Highest fertility rate in EU · 35h workweek · best healthcare · costly fuel/taxes',        highlights: { unemp: 7.9, gdp: '+0.7%', tax: '€1,802 SMIC' } },
  { ...de, slug: 'germany',     blurb: 'Largest EU economy · €2,222 min wage · top university system · sluggish growth',           highlights: { unemp: 4.0, gdp: '+0.3%', tax: '€12.82/hr' } },
  { ...it, slug: 'italy',       blurb: '5th most-visited globally · highest life expectancy · no statutory min wage',              highlights: { unemp: 5.2, gdp: '+0.6%', tax: 'CCNL' } },
  { ...nl, slug: 'netherlands', blurb: '5th largest EU economy · part-time capital · severe housing crisis · highest fuel',       highlights: { unemp: 3.9, gdp: '+1.8%', tax: '€2,070 min' } },
  { ...ie, slug: 'ireland',     blurb: 'Multinational hub · highest GDP/capita (inflated) · severe Dublin housing crisis',         highlights: { unemp: 4.5, gdp: '+4.5%', tax: '15% CT' } },
  { ...be, slug: 'belgium',     blurb: 'EU capital · highest tax wedge in OECD (53%) · 3 languages · strong public services',     highlights: { unemp: 5.5, gdp: '+1.2%', tax: '€2,070 min' } },
  { ...at, slug: 'austria',     blurb: 'Vienna = world\'s most-liveable city · hydro-powered grid · dual apprenticeship',         highlights: { unemp: 5.0, gdp: '+0.8%', tax: 'CCNL' } },
  { ...se, slug: 'sweden',      blurb: '5th biggest EU economy · 80% clean electricity · 480 days parental leave · gang concerns', highlights: { unemp: 8.0, gdp: '+1.6%', tax: 'CCNL' } },
  { ...pl, slug: 'poland',      blurb: 'Largest CEE economy · fastest big-EU growth · cheapest fuel · housing still affordable',  highlights: { unemp: 2.8, gdp: '+3.3%', tax: 'NBP rate' } },
  { ...cz, slug: 'czechia',     blurb: 'Most industrialised EU economy · lowest unemployment · Prague rivals Madrid in housing',   highlights: { unemp: 2.5, gdp: '+2.4%', tax: 'CZK' } },
  { ...gr, slug: 'greece',      blurb: 'EU\'s greatest recovery story · 207% → 142% debt · 36M tourists · brain drain slowing',   highlights: { unemp: 9.5, gdp: '+2.1%', tax: '€830 min' } },
  { ...dk, slug: 'denmark',     blurb: 'Highest GDP/capita in EU · world wind-power leader · #2 happiest globally',                highlights: { unemp: 5.5, gdp: '+2.5%', tax: 'CCNL' } },
  { ...fi, slug: 'finland',     blurb: 'Happiest country in the world (7y in a row) · cheap electricity · post-Russia transition', highlights: { unemp: 7.5, gdp: '+1.0%', tax: 'CCNL' } },
  { ...ee, slug: 'estonia',     blurb: 'EU\'s digital-government pioneer · lowest public debt in EU · long 2022–24 recession recovering',  highlights: { unemp: 7.5, gdp: '+2.0%', tax: 'e-Residency' } },
  { ...lv, slug: 'latvia',      blurb: 'Shrinking population · Riga Art Nouveau capital · cheap Latgale, expensive capital',                highlights: { unemp: 6.5, gdp: '+2.2%', tax: '€740 min' } },
  { ...lt, slug: 'lithuania',   blurb: 'Largest & fastest-growing Baltic · #2 EU fintech hub · highest NATO defence spending',              highlights: { unemp: 7.0, gdp: '+2.8%', tax: '€1,038 min' } },
  { ...hu, slug: 'hungary',     blurb: 'CEE auto powerhouse (Audi, BMW, BYD) · cheapest electricity in EU · 17% inflation 2023',            highlights: { unemp: 4.5, gdp: '+2.0%', tax: 'HUF' } },
  { ...sk, slug: 'slovakia',    blurb: 'World\'s biggest per-capita car producer · stark east–west divide · 55% nuclear power',             highlights: { unemp: 5.5, gdp: '+2.0%', tax: '€816 min' } },
  { ...si, slug: 'slovenia',    blurb: 'Wealthiest ex-Yugoslav state · Alpine + Adriatic mix · highest life expectancy in CEE',              highlights: { unemp: 3.8, gdp: '+2.3%', tax: '€1,254 min' } },
  { ...hr, slug: 'croatia',     blurb: 'EU\'s newest euro/Schengen member (2023) · tourism = 20% of GDP · debt 87% → 58% in 5 years',       highlights: { unemp: 5.5, gdp: '+3.0%', tax: '€970 min' } },
  { ...ro, slug: 'romania',     blurb: 'Largest IT sector in EU (% GDP) · Bucharest booming · 4M-strong diaspora · 7% deficit',             highlights: { unemp: 5.5, gdp: '+2.8%', tax: 'RON' } },
  { ...bg, slug: 'bulgaria',    blurb: 'Cheapest fuel in EU · poorest member · lowest public debt · adopts euro Jan 2026',                  highlights: { unemp: 4.5, gdp: '+2.5%', tax: '€550 min' } },
  { ...lu, slug: 'luxembourg',  blurb: 'Highest GDP/capita in EU · €2,704 min wage · finance hub · free public transport · 47% foreign',    highlights: { unemp: 5.8, gdp: '+2.0%', tax: '€2,704 min' } },
  { ...mt, slug: 'malta',       blurb: 'Fastest-growing EU economy · cheapest diesel · English-speaking · iGaming + fintech hub',           highlights: { unemp: 3.0, gdp: '+4.0%', tax: '€961 min' } },
  { ...cy, slug: 'cyprus',      blurb: 'Mediterranean island · post-2013 recovery (115% → 65% debt) · divided since 1974 · warmest in EU',  highlights: { unemp: 5.5, gdp: '+3.0%', tax: '€1,000 min' } },
];

// ── Group countries by region (same taxonomy as the Eubar dropdown) ───
const REGIONS = [
  { id: 'southern', emoji: '☀️', label: 'Southern Europe',           codes: ['pt','es','it','gr','hr','mt','cy'] },
  { id: 'western',  emoji: '🏛',  label: 'Western Europe',            codes: ['fr','de','nl','be','at','ie','lu'] },
  { id: 'central',  emoji: '🌲', label: 'Central & Eastern Europe',  codes: ['pl','cz','sk','si','hu','ro','bg'] },
  { id: 'nordic',   emoji: '❄️', label: 'Northern & Baltic',         codes: ['se','dk','fi','ee','lv','lt'] },
];
const byRegion = REGIONS.map((r) => ({
  ...r,
  items: r.codes.map((code) => countries.find((c) => c.meta.code === code)).filter(Boolean),
}));

// ── Auto-generated EU-27 rankings ─────────────────────────────────────
const fmt = (n: any) => (typeof n === 'number' ? n.toLocaleString('en-US') : String(n));
const top = (pick: (c: any) => number | null | undefined, dir: 'desc' | 'asc' = 'desc', limit = 10) => {
  return countries
    .map((c) => ({ flag: c.meta.flag, name: c.meta.name, slug: c.slug, val: pick(c) }))
    .filter((x) => typeof x.val === 'number' && !Number.isNaN(x.val))
    .sort((a, b) => (dir === 'desc' ? (b.val as number) - (a.val as number) : (a.val as number) - (b.val as number)))
    .slice(0, limit);
};

const rankings = [
  { title: '💶 Highest minimum wage',     items: top((c) => c.stats.minWage?.value, 'desc'), unit: '€/mo', note: 'Statutory only — IT/AT/SE/DK/FI use collective bargaining' },
  { title: '📉 Lowest unemployment',      items: top((c) => c.stats.unemployment?.value, 'asc'),   unit: '%' },
  { title: '🌍 Fastest GDP growth 2026',  items: top((c) => c.stats.gdp?.value, 'desc'),           unit: '%', prefix: '+' },
  { title: '🎂 Longest life expectancy',  items: top((c) => c.stats.lifeExpectancy?.value, 'desc'),unit: 'yrs' },
  { title: '📊 Lowest public debt',       items: top((c) => c.stats.publicDebt?.value, 'asc'),     unit: '% GDP' },
  { title: '⛽ Cheapest petrol 95',       items: top((c) => c.fuelFallback?.gasolina95?.atual, 'asc'), unit: '€/L' },
];
---
<BaseLayout
  title="EU Stats — Compare all 27 European countries for living, moving & investing"
  description="Side-by-side statistics for all 27 EU member states. Live data on fuel prices, housing, wages, unemployment, GDP, tourism and more — sourced from Eurostat, ECB and every national statistics office."
  current="home"
>
  <main class="main">
    <!-- Hero -->
    <section class="hero fade">
      <h1>
        Europe <em>by the Numbers</em>
      </h1>
      <p class="hero-lead">
        Side-by-side data for all 27 EU member states — for anyone thinking of moving, investing,
        or just curious how their country compares. Updated weekly from official sources.
      </p>
      <div class="hero-meta">
        <span class="hero-pill">⛽ Live fuel prices</span>
        <span class="hero-pill">🏠 Housing &amp; rent</span>
        <span class="hero-pill">💶 Wages &amp; unemployment</span>
        <span class="hero-pill">🗺 Interactive maps</span>
        <span class="hero-pill">📊 vs Europe comparisons</span>
      </div>
    </section>

    <!-- Region jump-nav — fast scan + anchors -->
    <nav class="region-nav fade" aria-label="Jump to region">
      {byRegion.map((r) => (
        <a href={`#region-${r.id}`} class="region-pill">
          <span class="region-pill-icon">{r.emoji}</span>
          <span class="region-pill-label">{r.label}</span>
          <span class="region-pill-count">{r.items.length}</span>
        </a>
      ))}
    </nav>

    <!-- Country cards grouped by region -->
    {byRegion.map((r) => (
      <section id={`region-${r.id}`} class="region-section fade">
        <header class="region-header">
          <h2 class="region-heading">{r.emoji} {r.label}</h2>
          <span class="region-count">{r.items.length} countries</span>
        </header>
        <div class="country-grid">
          {r.items.map((c) => (
            <a href={`${base}/${c.slug}`} class="country-card fade" data-country={c.meta.code}>
              <div class="cc-header">
                <span class="cc-flag">{c.meta.flag}</span>
                <div>
                  <div class="cc-name">{c.meta.name}</div>
                  <div class="cc-blurb">{c.blurb}</div>
                </div>
                <span class="cc-arrow">→</span>
              </div>
              <div class="cc-metrics">
                <div class="cc-metric">
                  <span class="cc-val">{c.fuelFallback.gasolina95.atual}€</span>
                  <span class="cc-lbl">Gasoline /L</span>
                </div>
                <div class="cc-metric">
                  <span class="cc-val">{c.highlights.unemp}%</span>
                  <span class="cc-lbl">Unemployment</span>
                </div>
                <div class="cc-metric">
                  <span class="cc-val">{c.highlights.gdp}</span>
                  <span class="cc-lbl">GDP 2026</span>
                </div>
                <div class="cc-metric">
                  <span class="cc-val">{c.stats.lifeExpectancy.value}y</span>
                  <span class="cc-lbl">Life expect.</span>
                </div>
              </div>
              <div class="cc-footer">
                <span class="cc-cats">⛽ 🏠 💶 🏥 🛡</span>
                <span class="cc-explore">Explore →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- Why this exists -->
    <section class="why fade">
      <h2>Why this exists</h2>
      <div class="why-grid">
        <div>
          <h3>🧭 For people moving</h3>
          <p>
            Real numbers — wages, rent, gasoline, taxes, healthcare — without the noise of
            travel-blog generalities. Each indicator includes its source and reference date.
          </p>
        </div>
        <div>
          <h3>📊 Live data</h3>
          <p>
            Fuel prices update weekly from the EU Oil Bulletin. Brent crude refreshes every
            30 min. Eurostat, ECB, INSEE, INE, ISTAT and Destatis power the deeper stats.
          </p>
        </div>
        <div>
          <h3>🆓 No tracking, no ads</h3>
          <p>
            Open-source, no analytics by default. The backend is a free-tier Node API on
            Render; the frontend is a static Astro site on GitHub Pages.
          </p>
        </div>
      </div>
    </section>

    <!-- Auto-generated EU-27 rankings (top 10 per metric) -->
    <section class="compare-teaser fade">
      <h2>Rankings across the EU-27</h2>
      <p class="compare-lead">Top 10 from every member state, computed automatically from the underlying data.</p>
      <div class="compare-grid">
        {rankings.map((r) => (
          <div class="compare-card">
            <div class="cmp-lbl">{r.title}</div>
            <ol class="cmp-list">
              {r.items.map((it, i) => (
                <li>
                  <span class="cmp-rank">{i + 1}</span>
                  <a class="cmp-country" href={`${base}/${it.slug}`}>
                    <span class="cmp-flag">{it.flag}</span>
                    <span class="cmp-name">{it.name}</span>
                  </a>
                  <span class="cmp-val">{r.prefix || ''}{fmt(it.val)}{r.unit ? ' ' + r.unit : ''}</span>
                </li>
              ))}
            </ol>
            {r.note && <div class="cmp-note">{r.note}</div>}
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero{margin:2.5rem 0 3.5rem;text-align:left}
  .hero h1{font-family:var(--font-d);font-size:3rem;font-weight:600;letter-spacing:-.02em;line-height:1.05;color:var(--text);margin-bottom:.8rem}
  .hero h1 em{font-style:italic;font-weight:300;color:var(--gold)}
  .hero-lead{font-size:1.15rem;color:var(--muted);max-width:720px;line-height:1.6}
  .hero-meta{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.5rem}
  .hero-pill{display:inline-flex;align-items:center;padding:.4rem .9rem;background:var(--surface);border:1px solid var(--border);border-radius:99px;font-size:.78rem;color:var(--muted)}

  /* Region jump-nav (pills) */
  .region-nav{display:flex;flex-wrap:wrap;gap:.5rem;margin:0 0 2.5rem;padding:.6rem;background:var(--surface);border:1px solid var(--border);border-radius:14px}
  .region-pill{display:inline-flex;align-items:center;gap:.5rem;padding:.45rem .9rem;background:transparent;border:1px solid transparent;border-radius:99px;color:var(--text);text-decoration:none;font-size:.85rem;transition:background .15s,border-color .15s}
  .region-pill:hover{background:var(--surface-2,#fafafa);border-color:var(--border)}
  .region-pill-icon{font-size:1rem;line-height:1}
  .region-pill-label{font-weight:500}
  .region-pill-count{font-size:.7rem;color:var(--muted);font-variant-numeric:tabular-nums;background:rgba(0,0,0,.05);padding:.1rem .45rem;border-radius:99px}

  /* Region sections */
  .region-section{margin-bottom:3rem;scroll-margin-top:80px}
  .region-header{display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:1.2rem;padding-bottom:.6rem;border-bottom:1px solid var(--border)}
  .region-heading{font-family:var(--font-d);font-size:1.5rem;font-weight:600;letter-spacing:-.01em;color:var(--text);margin:0}
  .region-count{font-size:.78rem;color:var(--muted);font-variant-numeric:tabular-nums;text-transform:uppercase;letter-spacing:.05em}

  .country-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:1.2rem}
  .country-card{
    background:var(--surface);border:1px solid var(--border);border-radius:14px;
    padding:1.5rem;transition:transform .18s, box-shadow .18s, border-color .18s;
    color:var(--text);
  }
  .country-card:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(0,0,0,.07);border-color:var(--accent-mid,#666)}
  .country-card[data-country="pt"]{--accent-mid:#1a6b40}
  .country-card[data-country="es"]{--accent-mid:#c0173a}
  .country-card[data-country="fr"]{--accent-mid:#002395}
  .country-card[data-country="de"]{--accent-mid:#1a1a1a}
  .country-card[data-country="it"]{--accent-mid:#008C45}
  .country-card[data-country="nl"]{--accent-mid:#21468B}
  .country-card[data-country="ie"]{--accent-mid:#169B62}
  .country-card[data-country="be"]{--accent-mid:#000000}
  .country-card[data-country="at"]{--accent-mid:#ED2939}
  .country-card[data-country="se"]{--accent-mid:#006AA7}
  .country-card[data-country="pl"]{--accent-mid:#dc143c}
  .country-card[data-country="cz"]{--accent-mid:#11457E}
  .country-card[data-country="gr"]{--accent-mid:#0D5EAF}
  .country-card[data-country="dk"]{--accent-mid:#C8102E}
  .country-card[data-country="fi"]{--accent-mid:#003580}
  .country-card[data-country="ee"]{--accent-mid:#0072CE}
  .country-card[data-country="lv"]{--accent-mid:#9E3039}
  .country-card[data-country="lt"]{--accent-mid:#006A44}
  .country-card[data-country="hu"]{--accent-mid:#477050}
  .country-card[data-country="sk"]{--accent-mid:#0B4EA2}
  .country-card[data-country="si"]{--accent-mid:#0F4DA8}
  .country-card[data-country="hr"]{--accent-mid:#171796}
  .country-card[data-country="ro"]{--accent-mid:#002B7F}
  .country-card[data-country="bg"]{--accent-mid:#00966E}
  .country-card[data-country="lu"]{--accent-mid:#00A1DE}
  .country-card[data-country="mt"]{--accent-mid:#C01C28}
  .country-card[data-country="cy"]{--accent-mid:#C8862B}

  .cc-header{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1rem}
  .cc-flag{font-size:2.4rem;line-height:1}
  .cc-name{font-family:var(--font-d);font-size:1.4rem;font-weight:600;color:var(--text)}
  .cc-blurb{font-size:.8rem;color:var(--muted);margin-top:.25rem;line-height:1.5}
  .cc-arrow{margin-left:auto;font-size:1.4rem;color:var(--muted);transition:transform .15s,color .15s}
  .country-card:hover .cc-arrow{transform:translateX(4px);color:var(--accent-mid)}

  .cc-metrics{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.5rem;padding:.8rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-bottom:.8rem}
  .cc-metric{text-align:center;padding:.3rem 0}
  .cc-val{display:block;font-family:var(--font-d);font-weight:600;font-size:1.15rem;color:var(--text)}
  .cc-lbl{display:block;font-size:.66rem;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;margin-top:.1rem}

  .cc-footer{display:flex;justify-content:space-between;align-items:center}
  .cc-cats{font-size:1rem;opacity:.7}
  .cc-explore{font-size:.78rem;color:var(--muted);font-weight:500}

  .why{margin:4rem 0;padding:2.5rem;background:var(--surface);border:1px solid var(--border);border-radius:14px}
  .why h2{font-family:var(--font-d);font-size:1.8rem;font-weight:600;margin-bottom:1.5rem}
  .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
  .why-grid h3{font-size:1rem;font-weight:500;margin-bottom:.5rem;color:var(--text)}
  .why-grid p{font-size:.88rem;color:var(--muted);line-height:1.6}

  .compare-teaser{margin:4rem 0 2rem}
  .compare-teaser h2{font-family:var(--font-d);font-size:1.8rem;font-weight:600;margin-bottom:.4rem}
  .compare-lead{font-size:.9rem;color:var(--muted);margin-bottom:1.5rem}
  .compare-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem}
  .compare-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.1rem 1.25rem}
  .cmp-lbl{font-size:.82rem;font-weight:500;color:var(--text);letter-spacing:.01em;margin-bottom:.7rem}
  .cmp-list{list-style:none;padding:0;margin:0;counter-reset:none}
  .cmp-list li{display:grid;grid-template-columns:1.2rem 1fr auto;align-items:center;gap:.5rem;padding:.32rem 0;font-size:.84rem;font-family:var(--font-m);border-top:1px solid var(--border)}
  .cmp-list li:first-child{border-top:none}
  .cmp-rank{font-size:.7rem;color:var(--muted);font-variant-numeric:tabular-nums;text-align:right}
  .cmp-country{display:inline-flex;align-items:center;gap:.4rem;color:var(--text);text-decoration:none;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .cmp-country:hover{color:var(--accent-mid,var(--gold))}
  .cmp-flag{font-size:1rem;line-height:1;flex-shrink:0}
  .cmp-name{font-family:var(--font-m);font-weight:500;overflow:hidden;text-overflow:ellipsis}
  .cmp-val{font-weight:600;font-variant-numeric:tabular-nums;color:var(--text);white-space:nowrap}
  .cmp-note{margin-top:.7rem;padding-top:.6rem;border-top:1px dashed var(--border);font-size:.7rem;color:var(--muted);line-height:1.4}
</style>
